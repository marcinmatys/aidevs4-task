OPENAI_MODEL=gpt-4o-mini

# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_MODEL=
AZURE_OPENAI_BASE_URL=

# Job Classification
JOB_CLASSIFICATION_BATCH_SIZE=10